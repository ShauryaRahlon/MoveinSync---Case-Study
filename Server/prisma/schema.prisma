generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  name            String
  role            String    @default("USER")
  isVerified      Boolean   @default(false)
  verificationOtp String?
  otpExpiry       DateTime?
  createdAt       DateTime  @default(now())
  bookings        Booking[]
}

model Stop {
  id               String      @id @default(uuid())
  name             String      @unique
  createdAt        DateTime    @default(now())
  bookingsAsDest   Booking[]   @relation("DestStop")
  bookingsAsSource Booking[]   @relation("SourceStop")
  routes           RouteStop[]
}

model Route {
  id        String      @id @default(uuid())
  name      String      @unique
  color     String
  createdAt DateTime    @default(now())
  stops     RouteStop[]
}

model RouteStop {
  id            String @id @default(uuid())
  stopId        String
  routeId       String
  sequenceOrder Int
  route         Route  @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stop          Stop   @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@unique([stopId, routeId])
  @@index([routeId, sequenceOrder])
}

model Booking {
  id                String   @id @default(uuid())
  userId            String
  sourceStopId      String
  destinationStopId String
  qrString          String   @unique
  routeDetails      Json
  status            String   @default("CONFIRMED")
  createdAt         DateTime @default(now())
  expiresAt         DateTime
  destinationStop   Stop     @relation("DestStop", fields: [destinationStopId], references: [id], onDelete: Cascade)
  sourceStop        Stop     @relation("SourceStop", fields: [sourceStopId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
